{
  "$ref": "#/definitions/fiches",
  "definitions": {
    "fiches": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "kicker": {
          "type": "string"
        },
        "hub": {
          "type": "string",
          "enum": [
            "eveil-a-soi",
            "eveil-au-soi"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "consultation",
            "stage",
            "atelier",
            "conference",
            "voyage",
            "parcours"
          ]
        },
        "order": {
          "type": "number",
          "default": 50
        },
        "lang": {
          "type": "string",
          "enum": [
            "fr",
            "en",
            "pl",
            "es",
            "it"
          ],
          "default": "fr"
        },
        "lede": {
          "type": "string"
        },
        "dates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "duration": {
          "type": "string"
        },
        "price": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "banner": {
          "type": "string"
        },
        "bannerAlt": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "imageAlt": {
          "type": "string"
        },
        "videos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "meta": {
                "type": "string"
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
