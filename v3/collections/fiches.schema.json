{
  "$ref": "#/definitions/fiches",
  "definitions": {
    "fiches": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "kicker": {
          "type": "string"
        },
        "hub": {
          "type": "string",
          "enum": [
            "eveil-a-soi",
            "eveil-au-soi"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "consultation",
            "stage",
            "atelier",
            "conference",
            "voyage",
            "parcours"
          ]
        },
        "order": {
          "type": "number",
          "default": 50
        },
        "stages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "lang": {
          "type": "string",
          "enum": [
            "fr",
            "en",
            "pl",
            "es",
            "it"
          ],
          "default": "fr"
        },
        "lede": {
          "type": "string"
        },
        "cardLede": {
          "type": "string"
        },
        "hideHeaderImage": {
          "type": "boolean",
          "default": false
        },
        "hideHeaderMeta": {
          "type": "boolean",
          "default": false
        },
        "practicalFooter": {
          "type": "boolean",
          "default": false
        },
        "richLayout": {
          "type": "string",
          "enum": [
            "sortir-matrice"
          ]
        },
        "pendingVideos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "meta": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "default": []
        },
        "videosHeading": {
          "type": "string"
        },
        "testimonials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "quote": {
                "type": "string"
              },
              "author": {
                "type": "string"
              }
            },
            "required": [
              "quote"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "bodyImage": {
          "type": "object",
          "properties": {
            "src": {
              "type": "string"
            },
            "alt": {
              "type": "string"
            },
            "caption": {
              "type": "string"
            }
          },
          "required": [
            "src"
          ],
          "additionalProperties": false
        },
        "dates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "duration": {
          "type": "string"
        },
        "price": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "banner": {
          "type": "string"
        },
        "bannerAlt": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "imageAlt": {
          "type": "string"
        },
        "audio": {
          "type": "string"
        },
        "audioTitle": {
          "type": "string"
        },
        "videos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "meta": {
                "type": "string"
              },
              "credit": {
                "type": "string",
                "enum": [
                  "debowska"
                ]
              },
              "cover": {
                "type": "string"
              },
              "coverAlt": {
                "type": "string"
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "kicker",
        "hub",
        "category",
        "lede"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}