# christinecal.com — hébergement mutualisé OVH (Apache)
# Ce fichier n'a d'effet que sur OVH ; il est ignoré par Vercel (preview /v3/).

# --- 1) HTTPS + domaine canonique (www) ---------------------------------
# OVH termine le TLS en amont : on teste X-Forwarded-Proto et NON %{HTTPS}
# (qui vaut « off » côté Apache même en HTTPS → boucle de redirection infinie).
RewriteEngine On
RewriteCond %{HTTP:X-Forwarded-Proto} !https [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.christinecal.com%{REQUEST_URI} [L,R=301]

# Redirections SEO « ancien WordPress → V3 » (301). URLs relevées dans l'export
# WP du site (sources/wp-v2). En V3 les fiches sont passées de la racine à leur
# hub (eveil-a-soi / eveil-au-soi). Les pages inchangées (/, /contact/, /mission/,
# /qui-suis-je/, /eveil-a-soi/, /eveil-au-soi/) n'ont pas besoin de règle.
RewriteRule ^construire-son-vaisseau-multidimensionnel-de-lame/?$      https://www.christinecal.com/eveil-a-soi/construire-son-vaisseau/ [L,R=301]
RewriteRule ^consultation-mediumnique/?$                              https://www.christinecal.com/eveil-a-soi/consultation-mediumnique/ [L,R=301]
RewriteRule ^sortir-de-sa-matrice-personnelle/?$                      https://www.christinecal.com/eveil-a-soi/sortir-de-sa-matrice/ [L,R=301]
RewriteRule ^stage-construction-de-la-merkaba-chritalline/?$          https://www.christinecal.com/eveil-a-soi/merkaba/ [L,R=301]
RewriteRule ^stage-construction-du-corps-de-lumiere/?$                https://www.christinecal.com/eveil-a-soi/corps-de-lumiere/ [L,R=301]
RewriteRule ^initiation-de-fin-de-cycle-et-multi-dimensionnalite-de-letre/?$ https://www.christinecal.com/eveil-au-soi/initiation-fin-de-cycle/ [L,R=301]
RewriteRule ^la-team-galactique-de-la-nouvelle-terre/?$              https://www.christinecal.com/eveil-au-soi/la-team-galactique/ [L,R=301]
RewriteRule ^les-7-rayons-7-jours-initiatiques/?$                    https://www.christinecal.com/eveil-au-soi/les-7-rayons/ [L,R=301]
RewriteRule ^les-extras-du-bugarach-et-ses-nouvelles-energies/?$      https://www.christinecal.com/eveil-au-soi/les-extras-du-bugarach/ [L,R=301]
RewriteRule ^les-intra-du-nouveau-telos-au-mont-shasta/?$            https://www.christinecal.com/eveil-au-soi/les-intra-telos-mont-shasta/ [L,R=301]
RewriteRule ^retrouver-sa-memoire-galactique/?$                      https://www.christinecal.com/eveil-au-soi/retrouver-sa-memoire-galactique/ [L,R=301]
RewriteRule ^semaine-initiatique-avec-lenergie-des-telosiens/?$      https://www.christinecal.com/eveil-au-soi/semaine-telosiens/ [L,R=301]
RewriteRule ^stage-de-lhomme-terrestre-a-lhumain-cosmique/?$          https://www.christinecal.com/eveil-au-soi/stage-homme-cosmique/ [L,R=301]
RewriteRule ^stage-du-corps-physique-au-temple-initiatique/?$        https://www.christinecal.com/eveil-au-soi/stage-corps-temple/ [L,R=301]
RewriteRule ^stage-mission-des-light-workers/?$                      https://www.christinecal.com/eveil-au-soi/stage-light-workers/ [L,R=301]
RewriteRule ^voyages-en-expansion-de-conscience-ou-voyage-astral/?$  https://www.christinecal.com/eveil-au-soi/voyages-expansion-conscience/ [L,R=301]
RewriteRule ^welcome(-new)?/?$                                        https://www.christinecal.com/ [L,R=301]

# --- 2) Page 404 personnalisée ------------------------------------------
ErrorDocument 404 /404.html

# --- 3) Compression -----------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# --- 4) Cache navigateur ------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
  # Assets fingerprintés par Astro (/_astro/...) : immuables, cache long
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML : toujours revalider pour servir la dernière version publiée
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
