---
import Base from '../../layouts/Base.astro';
import { ui } from '../../i18n/ui';
import { pathFor, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
---
<Base locale={locale} routeKey="home" title={t.meta.homeTitle} description={t.meta.homeDescription}>
  <section class="hero">
    <div class="hero__halo"></div>
    <div class="container">
      <p class="hero__eyebrow" data-hero="eyebrow">{t.hero.eyebrow}</p>
      <h1 class="hero__title" data-hero="title">
        Christine <span class="light">CAL</span>
      </h1>
      <p class="hero__tagline" data-hero="tagline">{t.hero.tagline}</p>
      <a class="btn btn--gold" href="#paths" data-hero="cta">{t.hero.scrollHint}</a>
    </div>
    <a class="hero__scroll" href="#paths" aria-hidden="true" tabindex="-1">{t.hero.scrollHint}</a>
  </section>

  <section class="paths" id="paths">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">✦</span>
        <h2>{t.paths.heading}</h2>
        <p class="lede">{t.paths.lede}</p>
      </div>
      <div class="portal-grid">
        <a class="portal-card" id="eveil-a-soi" href={pathFor('about', locale)} data-reveal>
          <span class="portal-card__kicker">{t.paths.aSoi.kicker}</span>
          <h3>{t.paths.aSoi.title}</h3>
          <p>{t.paths.aSoi.desc}</p>
          <ul>
            {t.paths.aSoi.items.map((item) => <li>{item}</li>)}
          </ul>
          <span class="portal-card__cta">{t.paths.cta}</span>
        </a>
        <a class="portal-card" id="eveil-au-soi" href={pathFor('about', locale)} data-reveal>
          <span class="portal-card__kicker">{t.paths.auSoi.kicker}</span>
          <h3>{t.paths.auSoi.title}</h3>
          <p>{t.paths.auSoi.desc}</p>
          <ul>
            {t.paths.auSoi.items.map((item) => <li>{item}</li>)}
          </ul>
          <span class="portal-card__cta">{t.paths.cta}</span>
        </a>
      </div>
    </div>
  </section>

  <section class="paper-section">
    <div class="container">
      <div class="paper-section__inner" data-reveal>
        <div class="about-teaser__grid">
          <div class="about-teaser__portrait">
            <img
              src="/images/christine-portrait.jpg"
              alt="Portrait de Christine CAL"
              width="600"
              height="719"
              loading="lazy"
            />
          </div>
          <div>
            <span class="eyebrow" style="color: var(--gold); letter-spacing: 0.3em; text-transform: uppercase; font-size: var(--text-xs);">
              {t.aboutTeaser.eyebrow}
            </span>
            <h2>{t.aboutTeaser.heading}</h2>
            <p>{t.aboutTeaser.body}</p>
            <div class="stats">
              {t.aboutTeaser.stats.map((s) => (
                <div class="stat">
                  <div class="stat__value">{s.value}</div>
                  <div class="stat__label">{s.label}</div>
                </div>
              ))}
            </div>
            <p style="margin-top: var(--space-4);">
              <a class="btn btn--ghost" href={pathFor('about', locale)}>{t.aboutTeaser.cta}</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="quote" data-reveal>
    <div class="container">
      <blockquote>{t.quote.text}</blockquote>
      <cite>{t.quote.author}</cite>
    </div>
  </section>

  <section class="contact-band" id="contact" data-reveal>
    <div class="container">
      <h2>{t.contact.heading}</h2>
      <p>{t.contact.body}</p>
      <div class="contact-band__actions">
        <a class="btn btn--gold" href="mailto:cc.christinecal@gmail.com">{t.contact.cta}</a>
        <a class="btn btn--ghost" href="tel:+33680428591">06 80 42 85 91</a>
      </div>
    </div>
  </section>
</Base>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);

    gsap
      .timeline({ defaults: { ease: 'power3.out' } })
      .from('[data-hero="eyebrow"]', { y: 24, opacity: 0, duration: 0.9 })
      .from('[data-hero="title"]', { y: 40, opacity: 0, duration: 1.1 }, '-=0.5')
      .from('[data-hero="tagline"]', { y: 24, opacity: 0, duration: 0.9 }, '-=0.6')
      .from('[data-hero="cta"]', { y: 16, opacity: 0, duration: 0.7 }, '-=0.5')
      .from('.hero__scroll', { opacity: 0, duration: 0.8 }, '-=0.2');

    for (const el of gsap.utils.toArray<HTMLElement>('[data-reveal]')) {
      gsap.from(el, {
        y: 48,
        opacity: 0,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 85%' },
      });
    }
  }
</script>
