# TinaCMS — identifiants Tina Cloud (à créer sur https://app.tina.io).
# Copier ce fichier en « .env » (git-ignoré) pour l'édition locale, et renseigner
# les MÊMES valeurs dans Vercel (Environment Variables) et dans les secrets
# GitHub Actions du déploiement OVH. Voir DEPLOY-CMS-TINA.md.

# Client ID du projet Tina Cloud (public, intégré au JS de /admin).
NEXT_PUBLIC_TINA_CLIENT_ID=

# Jeton de contenu Tina Cloud (lecture seule) — secret de build, NE PAS exposer.
TINA_TOKEN=

# Branche ciblée par Tina Cloud (optionnel ; défaut = main).
# GITHUB_BRANCH=main
