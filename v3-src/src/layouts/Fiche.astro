---
import Base from './Base.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import Slideshow from '../components/Slideshow.astro';
import { ui } from '../i18n/ui';
import { base, fichePath, hubs, locales, pathFor, type Locale } from '../i18n/utils';
import { getCollection, type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'fiches'>;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const t = ui[locale];
const f = entry.data;
const hub = hubs[f.hub];
const hubLabel = f.hub === 'eveil-a-soi' ? t.nav.eveilASoi : t.nav.eveilAuSoi;

// URL de cette fiche dans chaque langue (slugs identiques entre langues) :
// pour le canonical, les hreflang et le sélecteur de langue.
const slug = entry.id.replace(/^(en|pl|es|it)\//, '');
const alternates = Object.fromEntries(
  locales.map((l) => [l, fichePath(f.hub, slug, l)]),
) as Record<Locale, string>;

// Lignes d'infos pratiques (uniquement celles renseignées).
const facts = [
  f.format && { label: t.fiche.format, value: f.format },
  f.duration && { label: t.fiche.duration, value: f.duration },
  f.price && { label: t.fiche.price, value: f.price },
].filter(Boolean) as { label: string; value: string }[];

// Largeur native des images (pour les afficher au plus près de leur taille sans
// jamais les agrandir : les petites restent nettes, les bandeaux larges s'élargissent).
const IMG_W: Record<string, number> = {
  '/images/wp/bugarach.jpg': 1024,
  '/images/wp/chris-shasta.jpg': 400,
  '/images/wp/cote-de-jor.jpg': 600,
  '/images/wp/eneagramme.jpg': 600,
  '/images/wp/eveil-quantique.jpg': 600,
  '/images/wp/expansion-conscience.jpg': 600,
  '/images/wp/homme-aura.jpg': 600,
  '/images/wp/homme-debout-etoiles.jpg': 1400,
  '/images/wp/les-7-rayons.jpg': 1024,
  '/images/wp/les-freres-des-etoiles.jpg': 1740,
  '/images/wp/mediumnite.jpg': 500,
  '/images/wp/multidimensionnalite.jpg': 600,
  '/images/wp/nouvelle-ere.jpg': 566,
  '/images/wp/restructurer-adn.jpg': 600,
  '/images/wp/shasta1.jpg': 530,
  '/images/wp/stage-construction-corps-de-lumiere.jpg': 864,
  '/images/wp/stage-construction-merkaba-cristalline.jpg': 864,
  '/images/wp/stage-construction-vortex-ascentionnel.jpg': 864,
};
const imgMax = f.image ? Math.min(IMG_W[f.image] ?? 560, 880) : 560;

// Si cette fiche est une rubrique (elle regroupe des stages), on rend ses stages
// DANS la page (et non « en dessous » sur l'index du hub). Ordre = celui de `stages`.
const childSlug = (id: string) => id.replace(/^(en|pl|es|it)\//, '');
const stageEntries = f.stages.length
  ? (await getCollection('fiches', (e) => e.data.lang === locale && f.stages.includes(childSlug(e.id))))
      .sort((a, b) => f.stages.indexOf(childSlug(a.id)) - f.stages.indexOf(childSlug(b.id)))
  : [];
const stagesHeading: Record<Locale, string> = { fr: 'Au programme', en: 'Programme', pl: 'Program', es: 'Programa', it: 'Programma' };
const learnMore: Record<Locale, string> = { fr: 'En savoir plus', en: 'Learn more', pl: 'Dowiedz się więcej', es: 'Saber más', it: 'Scopri di più' };
---
<Base locale={locale} routeKey={hub.key} alternates={alternates} title={`${f.title} — Christine CAL`} description={f.lede}>
  <article class="fiche">
    {f.banner && (
      <figure class="fiche-banner">
        <img src={base + f.banner} alt={f.bannerAlt ?? f.imageAlt ?? f.title} fetchpriority="high" />
      </figure>
    )}
    <section class="page-hero fiche-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label={t.nav.breadcrumb}>
          <a href={pathFor('home', locale)}>{t.nav.home}</a>
          <span aria-hidden="true">/</span>
          <a href={pathFor(hub.key, locale)}>{hubLabel}</a>
        </nav>
        {f.kicker && <span class="eyebrow">{f.kicker}</span>}
        <h1>{f.title}</h1>
        <p class="lede">{f.lede}</p>
      </div>
    </section>

    {(facts.length > 0 || f.dates.length > 0) && !f.hideHeaderMeta && (
      <section class="container">
        <div class="fiche-meta">
          {f.dates.length > 0 && (
            <div class="fiche-meta__dates">
              <span class="fiche-meta__label">{t.fiche.dates}</span>
              <ul>
                {f.dates.map((d) => <li>{d}</li>)}
              </ul>
            </div>
          )}
          {facts.length > 0 && (
            <dl class="fiche-meta__facts">
              {facts.map((fact) => (
                <div>
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              ))}
            </dl>
          )}
        </div>
      </section>
    )}

    {f.slideshow.length > 0 ? (
      <section class="container">
        <Slideshow images={f.slideshow} alt={f.imageAlt ?? f.title} />
      </section>
    ) : f.image && !f.hideHeaderImage && (
      <section class="container">
        <figure class="fiche-image" style={`max-width: min(100%, ${imgMax}px)`}>
          <img src={base + f.image} alt={f.imageAlt ?? f.title} loading="lazy" />
        </figure>
      </section>
    )}

    {f.richLayout === 'sortir-matrice' ? (
      <section class="paper-section">
        <div class="container container--narrow">
          <div class="paper-section__inner sortir-rich" data-reveal>
            <figure class="sortir-hero-img">
              <img src={base + '/images/wp/old-life-new-life.jpg'} alt="D'une ancienne vie à une nouvelle vie" loading="lazy" />
            </figure>

            <h3 class="sortir-baseline"><em>Osez ! Vous ne vous reconnaîtrez plus, et votre entourage non plus.</em></h3>

            <div class="sortir-duo">
              <p class="sortir-duo__text">
                Transmuter la peur<br />en énergie positive<br />et passer d'une vie réactive<br />à une vie créative.
              </p>
              <figure class="sortir-duo__img">
                <img src={base + '/images/wp/chat-mirroir.jpg'} alt="Le chat qui se voit lion dans le miroir" loading="lazy" />
              </figure>
            </div>

            <div class="sortir-stage">
              <h3 class="sortir-stage-title">STAGE — TRANSMUTER SA PEUR DE BASE = MOTEUR D'INCARNATION N°1</h3>
              <p class="sortir-stage-sub">— Avec une approche différente de cet outil connu —</p>

              <div class="sortir-wheel">
                <figure class="sortir-wheel__img">
                  <img src={base + (f.image ?? '/images/wp/eneagramme.jpg')} alt={f.imageAlt ?? "L'énnéagramme"} loading="lazy" />
                </figure>
                <ul class="sortir-wheel__list">
                  <li>Découvrir cette source de souffrances permanentes.</li>
                  <li>Transmuter le continuum d'énergie dépensé à lutter contre la peur et le mettre à disposition de la mission.</li>
                  <li>Reconsidérer sa vie et ses relations du passé, dans le présent pour le futur.</li>
                  <li>S'offrir des relations harmonieuses et joyeuses avec soi et les autres.</li>
                </ul>
              </div>
              {(facts.length > 0 || f.dates.length > 0) && (
                <ul class="sortir-facts">
                  {facts.map((fact) => <li><span class="sortir-facts__label">{fact.label}</span> {fact.value}</li>)}
                  {f.dates.length > 0 && <li><span class="sortir-facts__label">{t.fiche.dates}</span> {f.dates.join(' · ')}</li>}
                </ul>
              )}
            </div>
          </div>
        </div>
      </section>
    ) : (
      <section class="paper-section">
        <div class:list={['container', { 'container--narrow': !f.wideBody }]}>
          <div class:list={['paper-section__inner', { 'has-bodyimage': f.bodyImage && !f.bodyImageBelow, 'is-wide': f.wideBody }]}>
            {f.bodyImage && !f.bodyImageBelow && (
              <figure class="fiche-bodyimage fiche-bodyimage--aside" data-reveal>
                <img src={base + f.bodyImage.src} alt={f.bodyImage.alt ?? ''} loading="lazy" />
                {f.bodyImage.caption && <figcaption>{f.bodyImage.caption}</figcaption>}
              </figure>
            )}
            <div class="prose">
              <slot />
            </div>
          </div>
        </div>
      </section>
    )}

    {f.bodyImage && (f.richLayout || f.bodyImageBelow) && (
      <section class="container container--narrow">
        <figure class="fiche-bodyimage" data-reveal>
          <img src={base + f.bodyImage.src} alt={f.bodyImage.alt ?? ''} loading="lazy" />
          {f.bodyImage.caption && <figcaption>{f.bodyImage.caption}</figcaption>}
        </figure>
      </section>
    )}

    {f.practicalFooter && (facts.length > 0 || f.dates.length > 0 || (f.image && f.hideHeaderImage && !f.richLayout)) && (
      <section class="container">
        <div class="fiche-practical" data-reveal>
          {f.image && f.hideHeaderImage && !f.richLayout && (
            <figure class="fiche-practical__img">
              <img src={base + f.image} alt={f.imageAlt ?? f.title} loading="lazy" />
            </figure>
          )}
          {f.dates.length > 0 && (
            <div class="fiche-practical__dates">
              <span class="fiche-meta__label">{t.fiche.dates}</span>
              <ul>
                {f.dates.map((d) => <li>{d}</li>)}
              </ul>
            </div>
          )}
          {facts.length > 0 && (
            <dl class="fiche-practical__facts">
              {facts.map((fact) => (
                <div>
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              ))}
            </dl>
          )}
        </div>
      </section>
    )}

    {f.gallery.length > 0 && (
      <section class="container container--narrow">
        <div class="fiche-gallery" data-reveal>
          {f.gallery.map((g) => (
            <figure>
              <img src={base + g.src} alt={g.alt ?? ''} loading="lazy" />
              {g.caption && <figcaption>{g.caption}</figcaption>}
            </figure>
          ))}
        </div>
      </section>
    )}

    {stageEntries.length > 0 && (
      <section class="container">
        <h2 class="fiche-stages-title">{stagesHeading[locale]}</h2>
        <div class="hub-grid">
          {stageEntries.map((st) => (
            <a class="portal-card" href={fichePath(f.hub, childSlug(st.id), locale)}>
              <span class="portal-card__kicker">{st.data.kicker}</span>
              <h3>{st.data.title}</h3>
              <p>{st.data.lede}</p>
              {st.data.dates.length > 0 && (
                <div class="portal-card__meta"><span>{st.data.dates[0]}</span></div>
              )}
              <span class="portal-card__cta">{learnMore[locale]}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {(f.videos.length > 0 || f.pendingVideos.length > 0) && (
      <section class="container">
        {f.videosHeading && <h2 class="fiche-videos-title">{f.videosHeading}</h2>}
        <div class="video-grid">
          {f.videos.map((v) => <VideoEmbed id={v.id} title={v.title} meta={v.meta} credit={v.credit} cover={v.cover} coverAlt={v.coverAlt} playLabel={t.video.play} />)}
          {f.pendingVideos.map((v) => (
            <figure class="video-card video-placeholder">
              <div class="video-placeholder__box" aria-hidden="true"><span>Vidéo<br /><small>à intégrer</small></span></div>
              <figcaption>
                {v.title && <strong>{v.title}</strong>}
                {v.meta && <span>{v.meta}</span>}
              </figcaption>
            </figure>
          ))}
          {f.audio && f.audioCover && (
            <figure class="video-card audio-card">
              <img class="audio-card__cover" src={base + f.audioCover} alt={f.audioTitle ?? 'Enregistrement'} loading="lazy" />
              <figcaption>
                <strong>Enregistrement</strong>
                {f.audioTitle && <span>{f.audioTitle}</span>}
                <audio controls preload="none" src={base + f.audio}></audio>
              </figcaption>
            </figure>
          )}
        </div>
      </section>
    )}

    {f.testimonials.length > 0 && (
      <section class="container container--narrow">
        <div class="fiche-testimonials" data-reveal>
          {f.testimonials.map((tm) => (
            <blockquote class="fiche-testimonial">
              <p>{tm.quote}</p>
              {tm.author && <cite>— {tm.author}</cite>}
            </blockquote>
          ))}
        </div>
      </section>
    )}

    {f.audio && !f.audioCover && (
      <section class="container">
        <figure class="fiche-audio">
          {f.audioTitle && <figcaption>{f.audioTitle}</figcaption>}
          <audio controls preload="none" src={base + f.audio}></audio>
        </figure>
      </section>
    )}

    <section class="contact-band">
      <div class="container">
        <h2>{f.category === 'consultation' ? t.fiche.ctaConsult : t.fiche.ctaDefault}</h2>
        <p>{t.contact.body}</p>
        <div class="contact-band__actions">
          <a class="btn btn--gold" href="mailto:cc.christinecal@gmail.com">{t.contact.cta}</a>
          <a class="btn btn--ghost" href={pathFor(hub.key, locale)}>← {hubLabel}</a>
        </div>
      </div>
    </section>

    {f.sideImages.length > 0 && (
      <script is:inline define:vars={{ items: f.sideImages.map((s) => ({ ...s, src: base + s.src })) }}>
        requestAnimationFrame(() => {
          for (const it of items) {
            // Ancre par id de titre, OU (repli) par un extrait de texte d'un
            // paragraphe/titre/liste du corps (« mets l'image à côté de ce texte »).
            let target = document.getElementById(it.section);
            if (!target) {
              const needle = it.section.toLowerCase();
              target = [...document.querySelectorAll('.prose p, .prose h2, .prose h3, .prose li, .prose blockquote')]
                .find((el) => el.textContent.toLowerCase().includes(needle));
            }
            if (!target || !target.parentNode) continue;
            const fig = document.createElement('figure');
            fig.className = 'prose-side-img prose-side-img--' + it.align + (it.size === 'small' ? ' prose-side-img--small' : '');
            const img = document.createElement('img');
            img.src = it.src; img.alt = it.alt || ''; img.loading = 'lazy';
            fig.appendChild(img);
            if (it.caption) {
              const fc = document.createElement('figcaption');
              fc.textContent = it.caption;
              fig.appendChild(fc);
            }
            target.parentNode.insertBefore(fig, target);
          }
        });
      </script>
    )}
  </article>
</Base>

<style>
  .fiche-banner {
    margin: 0; width: 100%; max-height: 44vh; overflow: hidden;
    border-bottom: 1px solid var(--border-light);
  }
  .fiche-banner img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    max-height: 44vh;
  }
  .fiche-audio {
    margin: 0; max-width: var(--container-narrow); margin-inline: auto;
    display: flex; flex-direction: column; gap: 0.7rem;
  }
  .fiche-audio figcaption {
    font-size: var(--text-sm); letter-spacing: 0.04em; color: var(--indigo-100);
  }
  .fiche-audio audio { width: 100%; }

  .fiche-stages-title {
    text-align: center; margin: var(--space-5) 0 var(--space-4);
    font-size: var(--text-2xl);
  }
  .fiche-videos-title {
    text-align: center; margin: 0 0 var(--space-4);
    font-size: var(--text-xl); font-family: var(--font-serif);
  }
  .fiche-bodyimage { margin: 0 auto; max-width: 520px; }
  .fiche-bodyimage img { width: 100%; display: block; border-radius: var(--radius); border: 1px solid var(--border-light); }
  .fiche-bodyimage figcaption { margin-top: 0.5rem; text-align: center; font-size: var(--text-sm); color: var(--ink-muted); font-style: italic; }
  /* L'aside flotte dans la carte papier (encre sombre OK) ; la version « en bas »
     est rendue sur le fond indigo → légende en couleur claire pour rester lisible. */
  .fiche-bodyimage:not(.fiche-bodyimage--aside) figcaption { color: var(--indigo-250); }

  /* bodyImage en aside flottant : le texte s'enroule autour → moins de scroll */
  .paper-section__inner.has-bodyimage::after { content: ''; display: block; clear: both; }
  .fiche-bodyimage--aside { max-width: 100%; margin: 0.25rem 0 var(--space-3); }
  @media (min-width: 720px) {
    .fiche-bodyimage--aside {
      float: right;
      width: clamp(220px, 36%, 320px);
      margin: 0.25rem 0 var(--space-3) var(--space-4);
    }
  }

  /* Témoignages (bas de fiche) */
  .fiche-testimonials { display: grid; gap: var(--space-3); }
  .fiche-testimonial {
    margin: 0; padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border-light);
    border-left: 3px solid var(--gold); border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.04);
  }
  .fiche-testimonial p { margin: 0 0 0.5em; font-style: italic; color: var(--indigo-100); }
  .fiche-testimonial cite { font-style: normal; font-size: var(--text-sm); color: var(--indigo-250); }

  /* Carte « enregistrement » (audio avec visuel) à côté de la vidéo */
  .audio-card { margin: 0; display: flex; flex-direction: column; }
  .audio-card__cover {
    width: 100%; display: block; border-radius: var(--radius);
    border: 1px solid var(--border-light);
  }
  .audio-card figcaption { margin-top: 0.7em; display: flex; flex-direction: column; gap: 0.3rem; }
  .audio-card figcaption strong { color: var(--gold-soft); letter-spacing: 0.04em; }
  .audio-card figcaption span { font-size: var(--text-sm); color: var(--indigo-250); }
  .audio-card audio { width: 100%; margin-top: 0.3rem; }

  /* Placeholders (images / vidéos à fournir) */
  .img-placeholder, .video-placeholder__box {
    border-radius: var(--radius); border: 1px dashed rgba(201, 169, 97, 0.5);
    background: rgba(85, 85, 85, 0.08);
    display: grid; place-items: center; text-align: center;
    color: var(--indigo-250); font-family: var(--font-serif); padding: var(--space-3);
  }
  .img-placeholder { aspect-ratio: 16 / 10; }
  .img-placeholder--square { aspect-ratio: 1 / 1; }
  .img-placeholder small, .video-placeholder__box small { opacity: 0.7; font-size: 0.8em; }
  .video-placeholder { margin: 0; }
  .video-placeholder__box { aspect-ratio: 16 / 9; }
  .video-placeholder figcaption { margin-top: 0.6rem; display: flex; flex-direction: column; gap: 0.15rem; }

  /* Encart « infos pratiques » en bas (page Consultation) : petite image + texte */
  .fiche-practical {
    width: fit-content; max-width: 100%; margin-inline: auto;
    display: flex; gap: var(--space-3) var(--space-5); align-items: flex-start;
    flex-wrap: wrap; justify-content: center;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border-light);
    border-top: 3px solid var(--gold);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.03);
  }
  .fiche-practical__img {
    margin: 0; flex: 0 0 clamp(120px, 22%, 180px);
    border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border-light);
  }
  .fiche-practical__img img { width: 100%; display: block; }
  .fiche-practical__facts { display: grid; gap: 0.6rem; margin: 0; }
  .fiche-practical__facts dt { font-size: var(--text-xs); letter-spacing: 0.1em; text-transform: uppercase; color: var(--indigo-300); }
  .fiche-practical__facts dd { margin: 0; font-family: var(--font-serif); font-size: var(--text-lg); color: var(--indigo-100); }
  .fiche-practical__dates .fiche-meta__label { font-size: var(--text-xs); letter-spacing: 0.1em; text-transform: uppercase; color: var(--indigo-300); }
  .fiche-practical__dates ul { margin: 0.3rem 0 0; padding-left: 1.1em; }
  .fiche-practical__dates li { font-family: var(--font-serif); font-size: var(--text-lg); color: var(--indigo-100); }

  /* Galerie d'images légendées (ex. Mont Shasta : livres, lieux, photos) */
  .fiche-gallery {
    display: grid; gap: var(--space-3); margin: var(--space-3) auto var(--space-4);
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  }
  .fiche-gallery figure { margin: 0; }
  .fiche-gallery img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    border-radius: var(--radius); border: 1px solid var(--border-light);
    aspect-ratio: 4 / 3;
  }
  .fiche-gallery figcaption {
    margin-top: 0.4rem; font-size: var(--text-sm); color: var(--indigo-250);
    font-style: italic; text-align: center;
  }

  /* Deux blocs côte à côte dans le corps d'une fiche (ex. Time line 1 / 2).
     Sur grand écran, le bloc « déborde » de la colonne de texte étroite pour
     offrir deux colonnes confortables (sinon elles sont trop fines). */
  :global(.prose .duo-cols) { display: grid; gap: var(--space-4); margin: var(--space-4) 0; }
  @media (min-width: 720px) { :global(.prose .duo-cols) { grid-template-columns: 1fr 1fr; } }

  /* Corps « large » (ex. Retrouver sa mémoire) : la carte papier prend toute la
     largeur pour des blocs côte à côte bien CARRÉS (pas en longueur), tout en
     gardant des lignes de texte lisibles (texte plafonné, duo-cols pleine largeur). */
  @media (min-width: 880px) {
    :global(.paper-section__inner.is-wide .prose > p),
    :global(.paper-section__inner.is-wide .prose > ul),
    :global(.paper-section__inner.is-wide .prose > h2),
    :global(.paper-section__inner.is-wide .prose > h3),
    :global(.paper-section__inner.is-wide .prose > blockquote) { max-width: 74ch; }
    :global(.paper-section__inner.is-wide .prose > .duo-cols) { max-width: none; }
  }
  :global(.prose .duo-col) {
    border: 1px solid var(--border-light); border-radius: var(--radius);
    padding: var(--space-3) var(--space-4); background: rgba(85, 85, 85, 0.05);
  }
  :global(.prose .duo-col h3) { margin-top: 0; }
  :global(.prose .duo-sub) {
    margin: 0 0 0.6em; font-family: var(--font-serif); letter-spacing: 0.08em;
    text-transform: uppercase; font-size: var(--text-sm); color: var(--gold);
  }

  /* Gabarit « Sortir de sa matrice » */
  .sortir-hero-img { margin: 0 auto var(--space-4); max-width: 420px; }
  .sortir-baseline { text-align: center; color: var(--ink); font-size: var(--text-xl); margin: 0 0 var(--space-4); }
  .sortir-duo, .sortir-wheel {
    display: grid; gap: var(--space-4); align-items: center; margin: var(--space-4) 0;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .sortir-duo { grid-template-columns: 1fr clamp(140px, 30%, 200px); }
    .sortir-wheel { grid-template-columns: clamp(190px, 40%, 300px) 1fr; }
  }
