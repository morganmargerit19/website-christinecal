---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/ui';
import { fichePath, pathFor } from '../../i18n/utils';

const locale = 'fr';
const t = ui[locale];

const fiches = (
  await getCollection('fiches', (e) => e.data.hub === 'eveil-a-soi' && e.data.lang === 'fr' && !e.data.draft)
).sort((a, b) => a.data.order - b.data.order);

const featured = fiches.filter((f) => f.data.featured);
const rest = fiches.filter((f) => !f.data.featured);
---
<Base
  locale={locale}
  routeKey="eveilASoi"
  title="Éveil à Soi — Christine CAL"
  description="Se rencontrer, se libérer du passé et devenir créateur de sa vie : consultations médiumniques, sortie de sa matrice et stages d'éveil quantique (École 5D)."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Éveil à Soi</span>
      <h1>Devenez créateur de votre vie</h1>
      <p class="lede">
        Se rencontrer, se libérer des blessures du passé et transmuter la peur en énergie au
        service de votre mission — par la consultation médiumnique, les outils de sortie de sa
        matrice personnelle et l'enseignement de l'École 5D.
      </p>
    </div>
  </section>

  <section class="container">
    <div class="hub-grid">
      {featured.map((f) => (
        <a class="portal-card portal-card--featured" href={fichePath('eveil-a-soi', f.id)}>
          <span class="portal-card__kicker">{f.data.kicker}</span>
          <h3>{f.data.title}</h3>
          <p>{f.data.lede}</p>
          <div class="portal-card__meta">
            {f.data.format && <span>{f.data.format}</span>}
            {f.data.duration && <span>{f.data.duration}</span>}
            {f.data.price && <span>{f.data.price}</span>}
          </div>
          <span class="portal-card__cta">Découvrir</span>
        </a>
      ))}
    </div>

    {rest.length > 0 && <p class="hub-section-title">Stages & ateliers d'éveil quantique</p>}

    <div class="hub-grid">
      {rest.map((f) => (
        <a class="portal-card" href={fichePath('eveil-a-soi', f.id)}>
          <span class="portal-card__kicker">{f.data.kicker}</span>
          <h3>{f.data.title}</h3>
          <p>{f.data.lede}</p>
          {f.data.dates.length > 0 && (
            <div class="portal-card__meta"><span>{f.data.dates[0]}</span></div>
          )}
          <span class="portal-card__cta">En savoir plus</span>
        </a>
      ))}
    </div>
  </section>

  <section class="contact-band">
    <div class="container">
      <h2>{t.contact.heading}</h2>
      <p>{t.contact.body}</p>
      <div class="contact-band__actions">
        <a class="btn btn--gold" href="mailto:cc.christinecal@gmail.com">{t.contact.cta}</a>
        <a class="btn btn--ghost" href={pathFor('home', locale)}>← {t.nav.home}</a>
      </div>
    </div>
  </section>
</Base>
