---
import { getCollection, render } from 'astro:content';
import Fiche from '../../../layouts/Fiche.astro';

export async function getStaticPaths() {
  const fiches = await getCollection(
    'fiches',
    (e) => e.data.hub === 'eveil-au-soi' && e.data.lang === 'pl' && !e.data.draft,
  );
  return fiches.map((entry) => ({
    params: { slug: entry.id.replace(/^pl\//, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Fiche entry={entry} locale="pl">
  <Content />
</Fiche>
