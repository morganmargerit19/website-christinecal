---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/ui';
import { fichePath, pathFor } from '../../i18n/utils';

const locale = 'fr';
const t = ui[locale];

const fiches = (
  await getCollection('fiches', (e) => e.data.hub === 'eveil-au-soi' && e.data.lang === 'fr' && !e.data.draft)
).sort((a, b) => a.data.order - b.data.order);
---
<Base
  locale={locale}
  routeKey="eveilAuSoi"
  title="Éveil au Soi — Christine CAL"
  description="Explorer plus grand que soi : mémoire galactique, Mont Shasta & nouveau TELOS, énergies du Bugarach et la team galactique de la Nouvelle Terre."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Éveil au Soi</span>
      <h1>Explorer plus grand que soi</h1>
      <p class="lede">
        Retrouver sa mémoire galactique, participer à la création de la Nouvelle Terre et explorer
        le Mont Shasta, le nouveau TELOS et les nouvelles énergies du Bugarach.
      </p>
    </div>
  </section>

  <section class="container">
    <div class="hub-grid">
      {fiches.map((f) => (
        <a class="portal-card" href={fichePath('eveil-au-soi', f.id)}>
          <span class="portal-card__kicker">{f.data.kicker}</span>
          <h3>{f.data.title}</h3>
          <p>{f.data.lede}</p>
          {f.data.dates.length > 0 && (
            <div class="portal-card__meta"><span>{f.data.dates[0]}</span></div>
          )}
          <span class="portal-card__cta">En savoir plus</span>
        </a>
      ))}
    </div>
  </section>

  <section class="contact-band">
    <div class="container">
      <h2>{t.contact.heading}</h2>
      <p>{t.contact.body}</p>
      <div class="contact-band__actions">
        <a class="btn btn--gold" href="mailto:cc.christinecal@gmail.com">{t.contact.cta}</a>
        <a class="btn btn--ghost" href={pathFor('home', locale)}>← {t.nav.home}</a>
      </div>
    </div>
  </section>
</Base>
