---
import Base from '../../layouts/Base.astro';
import { pathFor } from '../../i18n/utils';

const locale = 'en';
---
<Base
  locale={locale}
  routeKey="confidentialite"
  title="Privacy policy — Christine CAL"
  description="How your personal data is processed on Christine CAL's website, in accordance with the GDPR."
>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">GDPR</span>
      <h1>Privacy policy</h1>
      <p class="lede">Your data belongs to you. Here is how it is processed.</p>
    </div>
  </section>

  <section class="paper-section">
    <div class="container container--narrow">
      <div class="paper-section__inner prose">
        <h2>Data controller</h2>
        <p>
          The data collected on this site is processed by <strong>EURL Christine CAL</strong>,
          254 Chemin de la Terre Pointue, Castelgirou, 24 580 PLAZAC —
          <a href="mailto:cc.christinecal@gmail.com">cc.christinecal@gmail.com</a>.
        </p>

        <h2>Data collected and purpose</h2>
        <p>
          The site is a showcase: it does not create an account and does not collect any data without your knowledge.
          Only the information you voluntarily provide via the contact form
          or by e-mail (name, e-mail address, content of your message) is processed, for
          the sole purpose of <strong>responding to your request</strong>.
        </p>
        <p>
          Legal basis: your <strong>consent</strong> and the legitimate interest in responding to
          your request (art. 6 of the GDPR — EU Regulation 2016/679).
        </p>

        <h2>Recipients & retention</h2>
        <p>
          Your data is <strong>neither sold, transferred, nor disclosed</strong> to third parties for
          commercial purposes. It is kept for as long as necessary to process your
          request, then deleted (no later than 3 years after the last contact).
        </p>

        <h2>Your rights</h2>
        <p>In accordance with the GDPR and the French "Informatique et Libertés" Act (Law 78-17 of 6 January 1978), you have the following rights:</p>
        <ul>
          <li>right of access and information;</li>
          <li>right of rectification;</li>
          <li>right to erasure ("right to be forgotten");</li>
          <li>right to restriction of processing;</li>
          <li>right to object;</li>
          <li>right to data portability;</li>
          <li>right to set post-mortem directives.</li>
        </ul>
        <p>
          To exercise these rights, write to
          <a href="mailto:cc.christinecal@gmail.com">cc.christinecal@gmail.com</a>. In the event of a
          difficulty, you may lodge a complaint with the
          <strong>CNIL</strong> (3 place de Fontenoy, 75007 Paris —
          <a href="https://www.cnil.fr" rel="noopener">cnil.fr</a>).
        </p>

        <h2>Cookies</h2>
        <p>
          The use of cookies is detailed in the
          <a href={pathFor('cookies', locale)}>cookie policy</a>.
        </p>
      </div>
    </div>
  </section>
</Base>
