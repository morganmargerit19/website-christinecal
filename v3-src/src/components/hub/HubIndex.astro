---
import Base from '../../layouts/Base.astro';
import VideoEmbed from '../VideoEmbed.astro';
import { getCollection } from 'astro:content';
import { ui } from '../../i18n/ui';
import { base, fichePath, pathFor, type Locale } from '../../i18n/utils';
// FR éditable par Christine via le CMS (/admin → « Page : Éveil à Soi / au Soi »).
// Le formulaire écrit ces fichiers de données ; ne pas dupliquer le FR ci-dessous.
import eveilASoiFr from '../../data/eveil-a-soi.fr.json';
import eveilAuSoiFr from '../../data/eveil-au-soi.fr.json';

type Hub = 'eveil-a-soi' | 'eveil-au-soi';

interface Props {
  locale: Locale;
  hub: Hub;
}

const { locale, hub } = Astro.props;
const t = ui[locale];
const routeKey = hub === 'eveil-a-soi' ? 'eveilASoi' : 'eveilAuSoi';

// Contenu d'introduction par hub et par langue.
const intro: Record<Hub, Record<Locale, { title: string; desc: string; eyebrow: string; h1: string; lede: string; section: string }>> = {
  'eveil-a-soi': {
    fr: {
      title: eveilASoiFr.metaTitle,
      desc: eveilASoiFr.metaDesc,
      eyebrow: eveilASoiFr.eyebrow,
      h1: eveilASoiFr.h1,
      lede: eveilASoiFr.lede,
      section: '',
    },
    en: {
      title: 'Self-Awakening — Christine CAL',
      desc: 'Meet yourself, heal the past and become the creator of your life: mediumship consultations, stepping out of your matrix and quantum awakening retreats (5D School).',
      eyebrow: 'Self-Awakening',
      h1: 'Become the creator of your life',
      lede: 'Meet yourself, heal the wounds of the past and transmute fear into energy in service of your mission — through mediumship consultation, the tools for stepping out of your personal matrix, and the teaching of the 5D School.',
      section: 'Quantum awakening retreats & workshops',
    },
    pl: {
      title: 'Przebudzenie Siebie — Christine CAL',
      desc: 'Spotkać siebie, uwolnić się od przeszłości i zostać twórcą swojego życia: konsultacje mediumiczne, wyjście z matrycy i warsztaty przebudzenia kwantowego (Szkoła 5D).',
      eyebrow: 'Przebudzenie Siebie',
      h1: 'Zostań twórcą swojego życia',
      lede: 'Spotkać siebie, uwolnić się od ran przeszłości i przekształcić lęk w energię w służbie swojej misji — poprzez konsultację mediumiczną, narzędzia wyjścia z osobistej matrycy i nauczanie Szkoły 5D.',
      section: 'Warsztaty przebudzenia kwantowego',
    },
    es: {
      title: 'Despertar a Sí — Christine CAL',
      desc: 'Encontrarse, liberarse del pasado y convertirse en creador de tu vida: consultas de médium, salir de tu matriz y talleres de despertar cuántico (Escuela 5D).',
      eyebrow: 'Despertar a Sí',
      h1: 'Conviértete en creador de tu vida',
      lede: 'Encontrarse, liberarse de las heridas del pasado y transmutar el miedo en energía al servicio de tu misión — mediante la consulta de médium, las herramientas para salir de tu matriz personal y la enseñanza de la Escuela 5D.',
      section: 'Talleres de despertar cuántico',
    },
    it: {
      title: 'Risveglio a Sé — Christine CAL',
      desc: 'Incontrarsi, liberarsi dal passato e diventare creatore della propria vita: consulti medianici, uscita dalla propria matrice e seminari di risveglio quantico (Scuola 5D).',
      eyebrow: 'Risveglio a Sé',
      h1: 'Diventa il creatore della tua vita',
      lede: "Incontrarsi, liberarsi dalle ferite del passato e trasmutare la paura in energia al servizio della tua missione — attraverso il consulto medianico, gli strumenti per uscire dalla propria matrice personale e l'insegnamento della Scuola 5D.",
      section: 'Seminari di risveglio quantico',
    },
  },
  'eveil-au-soi': {
    fr: {
      title: eveilAuSoiFr.metaTitle,
      desc: eveilAuSoiFr.metaDesc,
      eyebrow: eveilAuSoiFr.eyebrow,
      h1: eveilAuSoiFr.h1,
      lede: eveilAuSoiFr.lede,
      section: '',
    },
    en: {
      title: 'Awakening to the Self — Christine CAL',
      desc: 'Exploring beyond yourself: galactic memory, Mount Shasta & the new TELOS, the energies of Bugarach and the galactic team of the New Earth.',
      eyebrow: 'Awakening to the Self',
      h1: 'Exploring beyond yourself',
      lede: 'Reconnect with your galactic memory, take part in the creation of the New Earth, and explore places of the 5th Dimension.',
      section: '',
    },
    pl: {
      title: 'Przebudzenie do Jaźni — Christine CAL',
      desc: 'Odkrywać to, co większe: pamięć galaktyczna, Mount Shasta i nowe TELOS, energie Bugarach oraz galaktyczny zespół Nowej Ziemi.',
      eyebrow: 'Przebudzenie do Jaźni',
      h1: 'Odkrywać to, co większe',
      lede: 'Odzyskać pamięć galaktyczną, uczestniczyć w tworzeniu Nowej Ziemi i odkrywać miejsca 5. Wymiaru.',
      section: '',
    },
    es: {
      title: 'Despertar al Sí — Christine CAL',
      desc: 'Explorar más allá de uno mismo: memoria galáctica, Monte Shasta y el nuevo TELOS, energías del Bugarach y el equipo galáctico de la Nueva Tierra.',
      eyebrow: 'Despertar al Sí',
      h1: 'Explorar más allá de uno mismo',
      lede: 'Reencontrar tu memoria galáctica, participar en la creación de la Nueva Tierra y explorar lugares de la 5ª Dimensión.',
      section: '',
    },
    it: {
      title: 'Risveglio al Sé — Christine CAL',
      desc: 'Esplorare oltre se stessi: memoria galattica, Monte Shasta e il nuovo TELOS, energie del Bugarach e il team galattico della Nuova Terra.',
      eyebrow: 'Risveglio al Sé',
      h1: 'Esplorare oltre se stessi',
      lede: 'Ritrovare la propria memoria galattica, partecipare alla creazione della Nuova Terra ed esplorare luoghi di 5ª Dimensione.',
      section: '',
    },
  },
};

const discover: Record<Locale, string> = { fr: 'Découvrir', en: 'Discover', pl: 'Odkryj', es: 'Descubrir', it: 'Scopri' };
const learnMore: Record<Locale, string> = { fr: 'En savoir plus', en: 'Learn more', pl: 'Dowiedz się więcej', es: 'Saber más', it: 'Scopri di più' };

// Titres des vidéos « Éveil à Soi » (IDs YouTube fixes, libellés traduits).
const eveilVideoTitles: { id: string; title: Record<Locale, string>; meta: string }[] = [
  {
    id: 'AvtWBNRF8vE',
    title: {
      fr: "La transition planétaire terrestre à l'ère du Verseau",
      en: 'The planetary transition of Earth in the Age of Aquarius',
      pl: 'Ziemska transformacja planetarna w erze Wodnika',
      es: 'La transición planetaria terrestre en la era de Acuario',
      it: "La transizione planetaria terrestre nell'era dell'Acquario",
    },
    meta: 'Juin 2017',
  },
  {
    id: 'rALVl8lKlBs',
    title: {
      fr: "Le défi de l'humanité actuelle",
      en: 'The challenge of humanity today',
      pl: 'Wyzwanie współczesnej ludzkości',
      es: 'El desafío de la humanidad actual',
      it: "La sfida dell'umanità attuale",
    },
    meta: 'Juin 2017',
  },
];

// Bloc éditorial « Éveil à Soi » (sous la bannière). Chaque paragraphe est une
// chaîne HTML (balises <em>/<strong> conservées). Le 1er paragraphe porte la
// classe de mise en avant, le 3e et le dernier la classe « strong » (cf. <style>).
const eveilIntro: Record<Locale, string[]> = {
  fr: eveilASoiFr.intro,
  en: [
    '<em>Revelations will multiply and lead humanity to awakening</em>',
    'The 4D energies unlock the doors of the unconscious that until now protected us.',
    'The return within becomes inevitable, for the outer world is bursting apart.',
    'Lifting our blocks and our fears, calming the mind and stabilising the emotions grant <strong>access to the consciousness of the Soul</strong>: this is what we call <em>the second birth</em>.',
    'For the awakened human, <strong>enduring one’s life is over</strong>.',
    'Now an awakened being, the task becomes to <strong>create it</strong>.',
    'Vibrating as an incarnated Soul, the conscious human accesses their multidimensionality.',
  ],
  pl: [
    '<em>Objawienia będą się mnożyć i poprowadzą ludzkość ku przebudzeniu</em>',
    'Energie 4D otwierają zamki nieświadomości, dotąd pełniącej rolę ochronną.',
    'Powrót do wnętrza staje się koniecznością, ponieważ świat zewnętrzny eksploduje.',
    'Uwolnienie blokad i lęków, uspokojenie umysłu i ustabilizowanie emocji otwierają <strong>dostęp do świadomości Duszy</strong>: mówimy o <em>drugich narodzinach</em>.',
    'Dla przebudzonego człowieka <strong>znoszenie swojego życia dobiegło końca</strong>.',
    'Stawszy się człowiekiem przebudzonym, ma teraz <strong>je tworzyć</strong>.',
    'Wibrując jako wcielona Dusza, świadomy człowiek uzyskuje dostęp do swojej wielowymiarowości.',
  ],
  es: [
    '<em>Las revelaciones se multiplicarán y conducirán a la humanidad al despertar</em>',
    'Las energías 4D hacen saltar los cerrojos del inconsciente hasta entonces protector.',
    'El retorno al interior se impone porque el exterior estalla.',
    'Liberar los bloqueos y los miedos, apaciguar la mente y estabilizar lo emocional permiten <strong>el acceso a la conciencia del Alma</strong>: se habla del <em>segundo nacimiento</em>.',
    'Para el humano despierto, <strong>padecer su vida ha terminado</strong>.',
    'Convertido en un humano despierto, se tratará de <strong>crearla</strong>.',
    'Vibrando como Alma encarnada, el humano consciente accede a su multidimensionalidad.',
  ],
  it: [
    '<em>Le rivelazioni si moltiplicheranno e condurranno l’umanità al risveglio</em>',
    'Le energie 4D fanno saltare i lucchetti dell’inconscio fino ad allora protettivo.',
    'Il ritorno all’interno si impone perché l’esterno esplode.',
    'Sciogliere i blocchi e le paure, placare la mente e stabilizzare l’emotività permettono <strong>l’accesso alla coscienza dell’Anima</strong>: si parla della <em>seconda nascita</em>.',
    'Per l’essere umano risvegliato, <strong>subire la propria vita è finito</strong>.',
    'Divenuto un essere umano risvegliato, si tratterà di <strong>crearla</strong>.',
    'Vibrando come Anima incarnata, l’essere umano consapevole accede alla propria multidimensionalità.',
  ],
};

// Bloc éditorial « Éveil au Soi » (sous la bannière). Paragraphes HTML.
const ausoIntro: Record<Locale, string[]> = {
  fr: eveilAuSoiFr.intro,
  en: [
    'The conscious personality, now partner of the Soul, continues the journey. It prepares for the <strong>fusion with the Higher SELF or I AM Presence</strong>, the non-incarnated part to be integrated through the multidimensional ascension process.',
    'The Soul then carries out the <strong>synthesis of this cycle and reintegrates its earthly fractals</strong>.',
    'Through the radiance of its frequency, it <strong>calls upon its Monadic family</strong>.',
    'To remember, to reconnect, to find oneself again becomes a need, even a necessity, in order to complete one’s individual and collective mission.',
    'The SELF or I AM Presence draws upon the 5D energies to descend gradually into the Soul, structured by its geometry and transformed into a <strong>true vessel of light</strong>.',
    '<strong>Connections with so-called future fractals or galactic parts</strong> allow the conscious Being, aided by Intra- or Extra-terrestrial Elder Brothers, to find again its true <strong>galactic family and history</strong>.',
  ],
  pl: [
    'Świadoma osobowość, partnerka Duszy, kontynuuje przygodę. Przygotowuje się do <strong>fuzji z Wyższym JA lub Obecnością I AM / JESTEM</strong>, niewcieloną częścią, którą należy zintegrować poprzez wielowymiarowy proces wniebowstąpienia.',
    'Dusza dokonuje wówczas <strong>syntezy tego cyklu i ponownie integruje swoje ziemskie fraktale</strong>.',
    'Poprzez promieniowanie swojej częstotliwości <strong>przywołuje swoją Monadyczną rodzinę</strong>.',
    'Pamiętać, połączyć się na nowo, odnaleźć siebie staje się potrzebą, a nawet koniecznością, by dokończyć swoją indywidualną i zbiorową misję.',
    'JA lub Obecność JESTEM korzysta z energii 5D, aby stopniowo zstąpić do Duszy, ustrukturyzowanej przez swoją geometrię i przemienionej w <strong>prawdziwy statek światła</strong>.',
    '<strong>Połączenia z tak zwanymi przyszłymi fraktalami lub częściami galaktycznymi</strong> pozwalają świadomej Istocie, wspieranej przez Wielkich Braci Wewnątrz- lub Pozaziemskich, odnaleźć swoją prawdziwą <strong>galaktyczną rodzinę i historię</strong>.',
  ],
  es: [
    'La personalidad consciente y compañera del Alma prosigue la aventura. Se prepara para la <strong>fusión con el SER Superior o Presencia I AM / YO SOY</strong>, parte no encarnada que debe integrarse mediante el proceso ascensional multidimensional.',
    'El Alma realiza entonces la <strong>síntesis de este ciclo y reintegra sus fractales terrestres</strong>.',
    'Por la radiancia de su frecuencia, <strong>llama a su familia Monádica</strong>.',
    'Recordar, reconectarse, reencontrarse se vuelve una necesidad, incluso una urgencia para concluir su misión individual y colectiva.',
    'El SER o Presencia YO SOY aprovecha las energías 5D para descender progresivamente en el Alma, estructurada por su geometría y transformada en un <strong>verdadero vehículo de luz</strong>.',
    'Unas <strong>conexiones con fractales llamados futuros o partes galácticas</strong> permiten al Ser consciente, ayudado por Grandes Hermanos Intra o Extraterrestres, reencontrar su verdadera <strong>familia e historia galáctica</strong>.',
  ],
  it: [
    'La personalità consapevole e partner dell\'Anima prosegue l\'avventura. Si prepara alla <strong>fusione con il SÉ Superiore o Presenza I AM / IO SONO</strong>, parte non incarnata da integrare attraverso il processo ascensionale multidimensionale.',
    'L\'Anima procede allora alla <strong>sintesi di questo ciclo e reintegra i suoi frattali terrestri</strong>.',
    'Attraverso la radianza della sua frequenza, <strong>chiama la sua famiglia Monadica</strong>.',
    'Ricordare, riconnettersi, ritrovarsi diventa un bisogno, persino una necessità per portare a termine la propria missione individuale e collettiva.',
    'Il SÉ o Presenza IO SONO approfitta delle energie 5D per scendere progressivamente nell\'Anima, strutturata dalla sua geometria e trasformata in un <strong>vero vascello di luce</strong>.',
    'Delle <strong>connessioni con frattali detti futuri o parti galattiche</strong> permettono all\'Essere consapevole, aiutato da Grandi Fratelli Intra o Extra terrestri, di ritrovare la sua vera <strong>famiglia e storia galattica</strong>.',
  ],
};

// Bloc de clôture « Éveil au Soi » (sous les cartes). FR éditable au CMS ;
// les autres langues seront resynchronisées par Morgan après validation.
const ausoOutro: Record<Locale, string[]> = {
  fr: eveilAuSoiFr.outro,
  en: [],
  pl: [],
  es: [],
  it: [],
};

const c = intro[hub][locale];

const fiches = (
  await getCollection('fiches', (e) => e.data.hub === hub && e.data.lang === locale && !e.data.draft)
).sort((a, b) => a.data.order - b.data.order);

const slugOf = (id: string) => id.replace(/^(en|pl|es|it)\//, '');
const featured = fiches.filter((f) => f.data.featured);
const rest = fiches.filter((f) => !f.data.featured);

// Les stages d'une rubrique vivent DANS la page de la rubrique (rendus par
// Fiche.astro), pas sur l'index. On les retire donc des cartes de l'index ;
// la rubrique reste une carte normale qui mène à sa page.
const childSlugs = new Set(rest.flatMap((f) => f.data.stages));
const cards = rest.filter((f) => !childSlugs.has(slugOf(f.id)));

// Texte affiché sur la carte (sous-titre de carte distinct du chapeau de page).
const cardText = (f: (typeof fiches)[number]) => f.data.cardLede ?? f.data.lede;

// Page « Éveil à Soi » : disposition voulue par Christine — Consultation et
// Sortir de sa matrice côte à côte, puis Construire le vaisseau plus grand
// dessous. On récupère les fiches par slug pour garder l'ordre demandé.
const bySlug = (s: string) => fiches.find((f) => slugOf(f.id) === s);
const eveilDuo = ['consultation-mediumnique', 'sortir-de-sa-matrice']
  .map(bySlug)
  .filter(Boolean) as typeof fiches;
const eveilVaisseau = bySlug('construire-son-vaisseau');
---
<Base locale={locale} routeKey={routeKey} title={c.title} description={c.desc}>
  <section class="page-hero hub-hero">
    <img
      class="hub-symbol"
      src={base + `/images/geometrie/${hub === 'eveil-a-soi' ? 'spirale-fibonacci' : 'fleur-de-vie'}.svg`}
      alt=""
      aria-hidden="true"
      loading="lazy"
    />
    <div class="container">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
    </div>
  </section>

  <section class="container">
    <figure class="hub-banner">
      <img
        src={base + (hub === 'eveil-au-soi' ? '/images/wp/bandeau-eveil-au-soi-2.jpg' : `/images/wp/bandeau-${hub}.jpg`)}
        alt=""
        aria-hidden="true"
        loading="lazy"
      />
    </figure>

    {hub === 'eveil-au-soi' && (
      <div class="auso-intro prose" data-reveal>
        {ausoIntro[locale].map((para) => (
          <p set:html={para} />
        ))}
      </div>
    )}

    {hub === 'eveil-a-soi' ? (
      <>
        <div class="eveil-intro" data-reveal>
          {eveilIntro[locale].map((para, i) => (
            <p
              class:list={[
                i === 0 && 'eveil-intro__hl',
                (i === 2 || i === eveilIntro[locale].length - 1) && 'eveil-intro__strong',
                i === 3 && 'eveil-intro__left',
              ]}
              set:html={para}
            />
          ))}
        </div>

        <div class="video-grid eveil-videos" data-reveal>
          {eveilVideoTitles.map((v) => (
            <VideoEmbed id={v.id} title={v.title[locale]} meta={v.meta} playLabel={t.video.play} />
          ))}
        </div>

        <div class="hub-grid hub-grid--duo" data-reveal>
          {eveilDuo.map((f) => (
            <a class="portal-card" href={fichePath(hub, slugOf(f.id), locale)}>
              <span class="portal-card__kicker">{f.data.kicker}</span>
              <h3>{f.data.title}</h3>
              <p>{cardText(f)}</p>
              <span class="portal-card__cta">{learnMore[locale]}</span>
            </a>
          ))}
        </div>

        {eveilVaisseau && (
          <a class="portal-card portal-card--featured eveil-vaisseau" data-reveal href={fichePath(hub, slugOf(eveilVaisseau.id), locale)}>
            <span class="portal-card__kicker">{eveilVaisseau.data.kicker}</span>
            <h3>{eveilVaisseau.data.title}</h3>
            <p>{cardText(eveilVaisseau)}</p>
            <span class="portal-card__cta">{discover[locale]}</span>
          </a>
        )}
      </>
    ) : (
      <>
        {featured.length > 0 && (
          <div class="hub-grid">
            {featured.map((f) => (
              <a class="portal-card portal-card--featured" href={fichePath(hub, slugOf(f.id), locale)}>
                <span class="portal-card__kicker">{f.data.kicker}</span>
                <h3>{f.data.title}</h3>
                <p>{cardText(f)}</p>
                <div class="portal-card__meta">
                  {f.data.format && <span>{f.data.format}</span>}
                  {f.data.duration && <span>{f.data.duration}</span>}
                  {f.data.price && <span>{f.data.price}</span>}
                </div>
                <span class="portal-card__cta">{discover[locale]}</span>
              </a>
            ))}
          </div>
        )}

        {cards.length > 0 && (
          <div class="hub-grid">
            {cards.map((f) => (
              <a class="portal-card" href={fichePath(hub, slugOf(f.id), locale)}>
                <span class="portal-card__kicker">{f.data.kicker}</span>
                <h3>{f.data.title}</h3>
                <p>{cardText(f)}</p>
                {f.data.stages.length === 0 && f.data.dates.length > 0 && (
                  <div class="portal-card__meta"><span>{f.data.dates[0]}</span></div>
                )}
                <span class="portal-card__cta">{f.data.stages.length > 0 ? discover[locale] : learnMore[locale]}</span>
              </a>
            ))}
          </div>
        )}

        {ausoOutro[locale].length > 0 && (
          <div class="hub-outro" data-reveal>
            {ausoOutro[locale].map((para, i) => (
              <p
                class:list={[i === ausoOutro[locale].length - 1 && 'hub-outro__tagline']}
                set:html={para}
              />
            ))}
          </div>
        )}
      </>
    )}
  </section>

  <section class="contact-band">
    <div class="container">
      <h2>{t.contact.heading}</h2>
      <p>{t.contact.body}</p>
      <div class="contact-band__actions">
        <a class="btn btn--gold" href="mailto:cc.christinecal@gmail.com">{t.contact.cta}</a>
        <a class="btn btn--ghost" href={pathFor('home', locale)}>← {t.nav.home}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hub-hero { position: relative; overflow: hidden; }
  .hub-hero .container { position: relative; z-index: 1; }
  .hub-symbol {
    position: absolute; z-index: 0; pointer-events: none;
    right: clamp(-50px, -1.5vw, 8px); top: 50%; transform: translateY(-50%);
    width: clamp(230px, 33vw, 430px); height: auto;
    opacity: 0.5;
    -webkit-mask-image: radial-gradient(closest-side, #000 78%, transparent 100%);
    mask-image: radial-gradient(closest-side, #000 78%, transparent 100%);
  }
  @media (max-width: 720px) { .hub-symbol { opacity: 0.28; right: -70px; } }

  /* Page « Éveil à Soi » — bloc éditorial sous la bannière */
  .eveil-intro {
    max-width: 60ch; margin: var(--space-5) auto var(--space-4);
    text-align: center; color: var(--indigo-100);
  }
  .eveil-intro p { margin: 0 0 0.9em; line-height: 1.6; }
  .eveil-intro__hl {
    font-family: var(--font-serif); font-size: var(--text-xl);
    color: var(--gold-soft); font-style: italic;
  }
  .eveil-intro__strong { font-weight: 600; color: var(--indigo-100); }
  /* Phrases longues alignées à gauche (souhait Christine : « à la ligne, non centrée ») */
  .eveil-intro__left { text-align: left; }

  .eveil-videos { margin-bottom: var(--space-5); }

  /* Page « Éveil au Soi » — texte d'introduction sous la bannière */
  .auso-intro {
    max-width: 68ch; margin: var(--space-5) auto var(--space-4);
    color: var(--indigo-100);
  }
  .auso-intro p { margin: 0 0 1em; line-height: 1.7; }
