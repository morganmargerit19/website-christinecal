---
import Base from '../../layouts/Base.astro';
import VideoEmbed from '../VideoEmbed.astro';
import { ui } from '../../i18n/ui';
import { base, pathFor, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];

type Crew = { title: string; en: string; desc: string };
type MissionContent = {
  metaTitle: string; metaDesc: string;
  eyebrow: string; h1: string; lede: string; bannerAlt: string;
  s1Heading: string; s1p1: string; s1p2: string;
  s2Heading: string; s2Quote: string; points: string[];
  pioneerAlt: string; pioneerHeading: string; pioneerIntro: string;
  pioneerQuotes: string[]; pioneerP2: string; pioneerP3: string;
  callEyebrow: string; callHeading: string; callHeadingEm: string; callLede: string;
  infinityAlt: string; crewOld: Crew; crewYoung: Crew;
  videos: { id: string; title: string; meta: string }[];
  recognizeHeading: string; recognizeBody: string; contactCta: string; back: string;
};

