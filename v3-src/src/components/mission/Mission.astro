const c = tr[locale];
---
<Base locale={locale} routeKey="mission" title={c.metaTitle} description={c.metaDesc}>
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" data-reveal>{c.eyebrow}</span>
      <h1 data-reveal>{c.h1}</h1>
      <p class="lede" data-reveal>{c.lede}</p>
    </div>
  </section>

  <section class="container">
    <figure class="mission-banner" data-reveal>
      <img src={base + '/images/wp/5emedimension.jpg'} alt={c.bannerAlt} loading="lazy" />
    </figure>
  </section>

  <section class="paper-section">
    <div class="container">
      <div class="paper-section__inner" data-reveal>
        <div class="mission-spacetime">
          <figure class="mission-spacetime__media">
            {/* TODO — Vidéo « spirale dorée du temps » (Shutterstock #1062052936),
                à intégrer une fois achetée par Christine. Placeholder en attendant. */}
            <div class="mission-spacetime__placeholder" aria-hidden="true">
              <span>Vidéo — spirale dorée du temps<br /><small>à intégrer (Shutterstock #1062052936)</small></span>
            </div>
          </figure>
          <div class="mission-spacetime__text prose">
            <h2>{c.s1Heading}</h2>
            <p>{c.s1p1}</p>
            <p>{c.s1p2}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="paper-section paper-section--soft">
    <div class="container container--narrow">
      <div class="paper-section__inner prose" data-reveal>
        <h2>{c.s2Heading}</h2>
        <blockquote>{c.s2Quote}</blockquote>
        <ul class="mission-points">
          {c.points.map((p) => <li>{p}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="paper-section">
    <div class="container">
      <div class="paper-section__inner" data-reveal>
        <div class="mission-pioneer">
          <figure class="mission-pioneer__img">
            <img src={base + '/images/wp/ascencion-396x600-1.jpg'} alt={c.pioneerAlt} loading="lazy" />
          </figure>
          <div class="mission-pioneer__text prose">
            <h2>{c.pioneerHeading}</h2>
            <p>{c.pioneerIntro}</p>
            <ul>
              {c.pioneerQuotes.map((q) => <li>{q}</li>)}
            </ul>
            <p>{c.pioneerP2}</p>
            <p>{c.pioneerP3}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="paper-section paper-section--soft">
    <div class="container">
      <div class="mission-call" data-reveal>
        <p class="eyebrow">{c.callEyebrow}</p>
        <h2>{c.callHeading} <em>{c.callHeadingEm}</em></h2>
        <p class="lede">{c.callLede}</p>
      </div>

      <div class="mission-infinity" data-reveal>
        <img
          class="mission-infinity__svg"
          src={base + '/images/geometrie/lemniscate.svg'}
          alt={c.infinityAlt}
          width="360"
          height="180"
        />
        <div class="mission-crews">
          <article class="crew">
            <h3>{c.crewOld.title}</h3>
            <p class="crew__en">{c.crewOld.en}</p>
            <p>{c.crewOld.desc}</p>
          </article>
          <article class="crew">
            <h3>{c.crewYoung.title}</h3>
            <p class="crew__en">{c.crewYoung.en}</p>
            <p>{c.crewYoung.desc}</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="container">
    <div class="video-grid">
      {c.videos.map((v) => <VideoEmbed id={v.id} title={v.title} meta={v.meta} playLabel={t.video.play} />)}
    </div>
  </section>

  <section class="contact-band">
    <div class="container">
      <h2>{c.recognizeHeading}</h2>
      <p>{c.recognizeBody}</p>
      <div class="contact-band__actions">
        <a class="btn btn--gold" href="mailto:cc.christinecal@gmail.com">{c.contactCta}</a>
        <a class="btn btn--ghost" href={pathFor('eveilAuSoi', locale)}>← {c.back}</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .mission-banner {
    margin: 0; border-radius: var(--radius, 16px); overflow: hidden;
    border: 1px solid var(--border-light);
  }
  .mission-banner img { width: 100%; height: clamp(220px, 40vh, 420px); object-fit: cover; object-position: center 22%; display: block; }

  .mission-points li { margin-bottom: 0.6em; }

  /* « L'Espace-Temps se contracte » : vidéo à gauche, texte à droite */
  .mission-spacetime {
    display: grid;
    grid-template-columns: clamp(220px, 38%, 360px) 1fr;
    gap: clamp(1.6rem, 4vw, 3rem);
    align-items: center;
  }
  .mission-spacetime__media { margin: 0; align-self: start; }
  .mission-spacetime__placeholder {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius);
    border: 1px dashed rgba(201, 169, 97, 0.55);
    background: var(--glass, rgba(16, 13, 46, 0.35));
    display: grid; place-items: center; text-align: center;
    padding: var(--space-3);
    color: var(--gold-soft); font-family: var(--font-serif);
  }
  .mission-spacetime__placeholder small { opacity: 0.7; font-size: 0.8em; }
  .mission-spacetime__text > :first-child { margin-top: 0; }
  @media (max-width: 600px) {
    .mission-spacetime { grid-template-columns: 1fr; gap: var(--space-3); }
    .mission-spacetime__media { width: 70%; margin: 0 auto; }
  }

  .mission-pioneer {
    display: grid;
    grid-template-columns: clamp(190px, 30%, 280px) 1fr;
    gap: clamp(1.6rem, 4vw, 3rem);
    align-items: center;
  }
  .mission-pioneer__img {
    margin: 0; align-self: start;
    border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border-light);
  }
  .mission-pioneer__img img { width: 100%; display: block; }
  .mission-pioneer__text > :first-child { margin-top: 0; }

  .mission-call { text-align: center; max-width: 46ch; margin: 0 auto var(--space-5); }
  .mission-call em { font-style: italic; color: var(--gold-soft); }

  .mission-infinity { display: flex; flex-direction: column; align-items: center; }
  .mission-infinity__svg { width: clamp(240px, 40vw, 380px); height: auto; margin-bottom: var(--space-2); }
  .mission-crews {
    display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.5rem, 4vw, 3.5rem);
    max-width: 860px; margin: 0 auto;
  }
  .crew {
    text-align: center;
    padding: clamp(1.2rem, 2.5vw, 1.8rem);
    border: 1px solid rgba(201, 169, 97, 0.28); border-radius: 16px;
    background: var(--glass, rgba(16, 13, 46, 0.35));
  }
  .crew h3 { font-family: var(--font-serif); color: var(--gold-soft); margin-bottom: 0.2rem; }
  .crew__en {
    font-size: var(--text-xs); letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--indigo-300); margin-bottom: 0.8rem;
  }
  @media (max-width: 600px) {
    .mission-crews { grid-template-columns: 1fr; }
    .mission-pioneer { grid-template-columns: 1fr; gap: var(--space-3); }
    .mission-pioneer__img { width: 60%; margin: 0 auto; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);
    for (const el of gsap.utils.toArray<HTMLElement>('[data-reveal]')) {
      gsap.from(el, {
        y: 40,
        opacity: 0,
        duration: 0.9,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 88%' },
      });
    }
  }
</script>
