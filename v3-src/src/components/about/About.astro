---
import Base from '../../layouts/Base.astro';
import VideoEmbed from '../VideoEmbed.astro';
import { about } from '../../i18n/pages/about';
import { ui } from '../../i18n/ui';
import { base, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = about[locale];
const u = ui[locale];
---
<Base locale={locale} routeKey="about" title={t.meta.title} description={t.meta.description}>
  <section class="page-hero about-hero">
    <img class="about-hero__symbol" src={base + '/images/geometrie/fleur-de-vie.svg'} alt="" aria-hidden="true" loading="lazy" />
    <div class="container">
      <span class="eyebrow" data-reveal>{t.hero.eyebrow}</span>
      <h1 data-reveal>{t.hero.title}</h1>
      {t.hero.lede && <p class="lede" data-reveal>{t.hero.lede}</p>}
      <p class="about-epigraph" data-reveal>{t.epigraph}</p>
    </div>
  </section>

  <section class="about-cosmic">
    <div class="container">
      <div class="about-intro about-intro--cosmic" data-reveal>
        <figure class="about-intro__portrait about-intro__portrait--cosmic">
          <img
            src={base + '/images/wp/ccal-portrait-2.jpg'}
            alt="Portrait de Christine CAL"
            loading="lazy"
          />
        </figure>
        <div class="about-intro__text about-intro__text--cosmic">
          <h2 class="about-galactic-heading">{t.galactic.heading}</h2>
          {t.galactic.items.map((item) => <p>{item}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section class="paper-section paper-section--soft">
    <div class="container container--narrow">
      <div class="paper-section__inner" data-reveal>
        <h2 class="about-h2">{t.journey.heading}</h2>
        <ol class="about-timeline about-timeline--compact">
          {t.journey.items.map((item) => (
            <li>
              <span class="about-timeline__lead">{item.lead}</span>
              <span class="about-timeline__text" set:html={item.text} />
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="paper-section">
    <div class="container">
      <div class="paper-section__inner" data-reveal>
        <h2 class="about-h2">{t.activities.heading}</h2>
        <div class="about-cards">
          {t.activities.items.map((item) => (
            <article class:list={["about-card", item.accordion && "about-card--wide"]}>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              {item.accordion && (
                <details class="about-accordion">
                  <summary>{item.accordion.summary}</summary>
                  <ul>
                    {item.accordion.items.map((conf) => <li>{conf}</li>)}
                  </ul>
                </details>
              )}
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="paper-section paper-section--soft">
    <div class="container">
      <div class="paper-section__inner" data-reveal>
        <div class="about-duo">
          {t.specifics && (
            <div class="about-duo__col">
              <h2 class="about-h2">{t.specifics.heading}</h2>
              <ul class="about-news">
                {t.specifics.items.map((item) => <li set:html={item} />)}
              </ul>
            </div>
          )}
          <div class="about-duo__col">
            <h2 class="about-h2">{t.news.heading}</h2>
            <ul class="about-news">
              {t.news.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="paper-section paper-section--soft">
    <div class="container">
      <div class="paper-section__inner" data-reveal>
        <div class="about-duo">
          {t.upcoming && (
            <div class="about-duo__col">
              <h2 class="about-h2">{t.upcoming.heading}</h2>
              <ul class="about-news">
                {t.upcoming.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          )}
          <div class="about-duo__col">
            <div class="about-clients">
              <h3>{t.clients.heading}</h3>
              <p>{t.clients.text}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="paper-section">
    <div class="container container--narrow">
      <div class="paper-section__inner" data-reveal>
        <h2 class="about-h2">{t.videos.heading}</h2>
        <div class="video-grid">
          {t.videos.list.map((v) => (
            <VideoEmbed id={v.id} title={v.title} meta={v.meta} playLabel={u.video.play} />
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Titres de section sur papier */
  .about-h2 {
    font-family: var(--font-serif); color: var(--ink); margin: 0 0 var(--space-3);
    font-size: var(--text-xl);
  }
  .about-h3 { font-family: var(--font-serif); color: var(--ink); margin: var(--space-4) 0 var(--space-2); }

  /* Épigraphe : portrait poétique en ouverture, mis à part du reste */
  .about-epigraph {
    margin: var(--space-4) auto 0; max-width: 46ch;
    font-family: var(--font-serif); font-style: italic;
    font-size: var(--text-lg); line-height: 1.6;
    color: var(--indigo-100); position: relative;
    padding-top: var(--space-3);
  }
  .about-epigraph::before {
    content: "✦"; display: block; margin: 0 auto var(--space-2);
    color: var(--gold); font-style: normal; font-size: 0.9em;
  }

  /* Fleur de vie en filigrane derrière le titre (univers de Christine) */
  .about-hero { position: relative; overflow: hidden; }
  .about-hero .container { position: relative; z-index: 1; }
  .about-hero__symbol {
    position: absolute; z-index: 0; pointer-events: none;
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: min(72vw, 540px); height: auto; opacity: 0.12;
    -webkit-mask-image: radial-gradient(closest-side, #000 52%, transparent 100%);
    mask-image: radial-gradient(closest-side, #000 52%, transparent 100%);
  }

  /* Portrait à côté du premier bloc de texte (moins de scroll) */
  .about-intro { display: grid; gap: var(--space-4); align-items: center; }
  @media (min-width: 760px) {
    .about-intro { grid-template-columns: minmax(220px, 300px) 1fr; gap: var(--space-5); }
  }
  .about-intro__portrait {
    margin: 0; border-radius: var(--radius-lg); overflow: hidden;
    box-shadow: var(--shadow-md); border: 1px solid var(--border-light);
    max-width: 320px; justify-self: center;
  }
  .about-intro__portrait img { width: 100%; display: block; }
  .about-intro__text :first-child { margin-top: 0; }

  /* Parcours = timeline dorée */
  .about-timeline { list-style: none; margin: 0; padding: 0; position: relative; }
  .about-timeline::before {
    content: ""; position: absolute; left: 7px; top: 8px; bottom: 12px; width: 2px;
    background: linear-gradient(180deg, var(--gold), rgba(201,169,97,0.15));
  }
  .about-timeline li { position: relative; padding: 0 0 var(--space-4) calc(var(--space-4) + 0.4rem); }
  .about-timeline li:last-child { padding-bottom: 0; }
  .about-timeline li::before {
    content: ""; position: absolute; left: 0; top: 6px; width: 16px; height: 16px;
    border-radius: 50%; border: 2px solid var(--gold); background: var(--paper);
    box-shadow: 0 0 0 4px rgba(201,169,97,0.12);
  }
  /* Titres de la timeline : police lisible (corps) plutôt que la serif
     décorative Cormorant, jugée trop difficile à lire (retour Christine). */
  .about-timeline__lead {
    display: block; font-family: var(--font-sans); font-weight: 600;
    font-size: var(--text-md, 1.05rem); letter-spacing: 0.005em;
    color: var(--ink); line-height: 1.3; margin-bottom: 0.2em;
  }
  .about-timeline__text { color: var(--ink-soft); }

  /* Mise en évidence des termes clés (or/accent) — souhait de Christine.
     `:global` car ces <strong> sont injectés via set:html (non scopés). */
  :global(.about-accent) { color: var(--gold); font-weight: 700; }

  /* Activités = cartes */
  .about-cards { display: grid; gap: var(--space-3); }
  @media (min-width: 620px) { .about-cards { grid-template-columns: 1fr 1fr; } }
  .about-card {
    padding: var(--space-3); border-radius: var(--radius);
    background: var(--paper-soft); border: 1px solid rgba(22,20,51,0.07);
    border-left: 3px solid var(--gold);
  }
  .about-card h3 { margin: 0 0 0.3em; font-family: var(--font-serif); color: var(--ink); font-size: var(--text-lg); }
  .about-card p { margin: 0; color: var(--ink-soft); font-size: var(--text-sm); }
  /* La carte « Conférencière » (avec accordéon) reste sur une seule colonne
     afin que la carte « Organisatrice » se place juste à côté (retour Christine). */
  .about-card--wide { grid-column: auto; }

  /* « Une galactique venue d'un futur » : en italique et en bleu (souhait de Christine).
     Bleu clair (indigo-200) car le bloc est désormais sur le fond étoilé sombre. */
  .about-galactic-heading { font-style: italic; color: var(--indigo-200); }

  /* Bloc photo + « galactique » SANS carte blanche : sur le fond cosmique (étoiles),
     comme la section « Vous sentez l'appel » de Mission, que Christine adore. */
  /* Bandeau cosmique : la photo de Christine posée sur l'image galaxie (Terre/Lune),
     voile indigo pour la lisibilité du texte clair, fondu haut/bas dans la page. */
  .about-cosmic {
    position: relative; padding-block: var(--space-6);
    background-image:
      linear-gradient(180deg, var(--indigo-950) 0%, rgba(7, 6, 26, 0.5) 24%, rgba(7, 6, 26, 0.55) 76%, var(--indigo-950) 100%),
      url('/images/wp/galaxie-terre.jpg');
    background-size: cover; background-position: center;
  }
  .about-intro--cosmic { display: grid; gap: var(--space-4); align-items: center; }
  @media (min-width: 760px) {
    .about-intro--cosmic { grid-template-columns: minmax(220px, 300px) 1fr; gap: var(--space-5); }
  }
  .about-intro__text--cosmic { color: var(--indigo-100); }
  .about-intro__text--cosmic p { color: var(--indigo-100); margin: 0 0 0.8em; }
  /* Portrait posé dans le cosmos : halo doré/indigo derrière, fin liseré or, lueur */
  .about-intro__portrait--cosmic {
    position: relative; margin: 0; justify-self: center;
    max-width: 320px; border-radius: var(--radius-lg); overflow: visible;
    border: none; box-shadow: none;
  }
  .about-intro__portrait--cosmic img {
    width: 100%; display: block; border-radius: var(--radius-lg);
    border: 1px solid rgba(230, 212, 154, 0.45);
    box-shadow: 0 0 50px rgba(201, 169, 97, 0.25), 0 18px 50px rgba(7, 6, 26, 0.55);
    position: relative; z-index: 1;
  }
  .about-intro__portrait--cosmic::before {
    content: ""; position: absolute; inset: -22%; z-index: 0; border-radius: 50%;
    background: radial-gradient(circle, rgba(123, 121, 198, 0.38), rgba(201, 169, 97, 0.12) 46%, transparent 72%);
    filter: blur(8px); pointer-events: none;
  }

  /* Parcours en bref : version compacte (« prendre moins de place ») */
  .about-timeline--compact li { padding-bottom: var(--space-3); }
  .about-timeline--compact .about-timeline__lead { font-size: var(--text-base, 1rem); margin-bottom: 0.1em; }

  /* Accordéon des conférences (replié par défaut, comme l'ancien WordPress) */
  .about-accordion { margin-top: var(--space-2); }
  .about-accordion summary {
    cursor: pointer; list-style: none; font-family: var(--font-serif);
    color: var(--indigo-700); font-weight: 600; font-size: 1.05rem; letter-spacing: 0.02em;
    padding: 0.35em 0; user-select: none;
  }
  .about-accordion summary::-webkit-details-marker { display: none; }
  .about-accordion summary::before { content: "▸ "; color: var(--gold); }
  .about-accordion[open] summary::before { content: "▾ "; }
  .about-accordion ul {
    list-style: none; margin: 0.4em 0 0; padding: 0;
    columns: 1; column-gap: var(--space-4);
  }
  .about-accordion li {
    break-inside: avoid; margin-bottom: 0.45em;
    padding-left: 1em; position: relative;
    color: var(--ink-soft); font-size: var(--text-sm);
  }
  .about-accordion li::before { content: "✴"; position: absolute; left: 0; color: var(--gold); font-size: 0.8em; }
  @media (max-width: 600px) { .about-accordion ul { columns: 1; } }

  /* SPÉCIFICITÉS & ACTUALITÉS : deux colonnes côte à côte (empilées sur mobile) */
  .about-duo { display: grid; gap: var(--space-4); }
  @media (min-width: 760px) {
    .about-duo { grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: start; }
  }
  .about-duo .about-h2 { margin-top: 0; }
  .about-duo .about-news { margin-bottom: 0; }
  .about-duo .about-clients { margin: 0; }

  /* Actualités = liste ✦ */
  .about-news { list-style: none; margin: 0 0 var(--space-4); padding: 0; }
  .about-news li { position: relative; padding-left: 1.6em; margin-bottom: 0.7em; color: var(--ink-soft); }
  .about-news li::before { content: "✦"; position: absolute; left: 0; top: 0.05em; color: var(--gold); }

  /* Clientèle = encart sobre */
  .about-clients {
    border-left: 3px solid var(--indigo-300); padding: var(--space-1) 0 var(--space-1) var(--space-3);
    margin: var(--space-4) 0;
  }
  .about-clients h3 { margin: 0 0 0.3em; font-family: var(--font-serif); color: var(--ink); }
  .about-clients p { margin: 0; color: var(--ink-soft); font-style: italic; }
  .about-dvd { margin-top: var(--space-3); }
  .about-dvd__intro { margin: 0 0 var(--space-4); }
  .about-dvd__grid {
    display: grid; gap: var(--space-4); align-items: center;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) { .about-dvd__grid { grid-template-columns: 280px 1fr; } }
  .about-dvd__poster {
    margin: 0; border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--border-light); box-shadow: var(--shadow-md);
  }
  .about-dvd__poster img { width: 100%; display: block; }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion) {
    gsap.registerPlugin(ScrollTrigger);
    for (const el of gsap.utils.toArray<HTMLElement>('[data-reveal]')) {
      gsap.from(el, {
        y: 40,
        opacity: 0,
        duration: 0.9,
        ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 88%' },
      });
    }
  }
</script>
