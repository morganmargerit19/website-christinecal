---
/**
 * Bloc « Deux images côte à côte » — remplace le HTML `<div class="media-duo">`.
 * float:true = variante « livres » qui flotte à droite, le texte s'enroule à gauche.
 */
import { base } from '../../i18n/utils';

interface Props {
  images?: { src: string; alt?: string; caption?: string }[];
  float?: boolean;
}
const { images = [], float = false } = Astro.props;
---
<div class:list={['block-mediaduo', { 'block-mediaduo--float': float }]}>
  {images.map((im) => (
    <figure>
      <img src={base + im.src} alt={im.alt ?? ''} loading="lazy" />
      {im.caption && <figcaption set:html={im.caption} />}
    </figure>
  ))}
</div>

<style>
  .block-mediaduo {
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2, 1rem);
    margin: 0.25rem 0 var(--space-3, 1.5rem);
  }
  .block-mediaduo figure { margin: 0; }
  .block-mediaduo img {
    width: 100%; height: auto; display: block;
    border-radius: var(--radius, 14px); border: 1px solid rgba(22, 20, 51, 0.12);
  }
  .block-mediaduo figcaption {
    margin-top: 0.3rem; font-size: var(--text-xs, 0.8rem);
    font-style: italic; text-align: center; color: var(--ink-muted, #6b6b6b);
  }
  @media (min-width: 720px) {
    .block-mediaduo--float {
      float: right; width: clamp(220px, 34%, 320px);
      margin: 0.25rem 0 var(--space-3, 1.5rem) var(--space-4, 2rem);
    }
  }
</style>
