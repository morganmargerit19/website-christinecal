---
/**
 * Bloc « Galerie » — rangée d'images légendées en grille (ex. photos d'un lieu).
 */
import { base } from '../../i18n/utils';

interface Props {
  images?: { src: string; alt?: string; caption?: string }[];
}
const { images = [] } = Astro.props;
---
<div class="block-gallery">
  {images.map((g) => (
    <figure>
      <img src={base + g.src} alt={g.alt ?? ''} loading="lazy" />
      {g.caption && <figcaption>{g.caption}</figcaption>}
    </figure>
  ))}
</div>

<style>
  .block-gallery {
    display: grid; gap: var(--space-3, 1.5rem);
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    margin: var(--space-3, 1.5rem) 0; clear: both;
  }
  .block-gallery figure { margin: 0; }
  .block-gallery img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius, 14px); border: 1px solid var(--border-light, rgba(22, 20, 51, 0.12));
  }
  .block-gallery figcaption {
    margin-top: 0.4rem; font-size: var(--text-sm, 0.9rem);
    font-style: italic; text-align: center; color: var(--ink-muted, #6b6b6b);
  }
</style>
