---
/**
 * Diaporama simple et léger (sans dépendance) : fondu enchaîné automatique,
 * navigation par points, respect de prefers-reduced-motion.
 * Souhait de Christine (page Mont Shasta) : un diaporama de photos plutôt
 * qu'une seule photo.
 */
import { base } from '../i18n/utils';

interface Props {
  images: string[];
  alt?: string;
}
const { images, alt = '' } = Astro.props;
---
<div class="slideshow" data-slideshow>
  {images.map((src, i) => (
    <figure class="slideshow__slide" data-active={i === 0 ? 'true' : 'false'}>
      <img src={base + src} alt={i === 0 ? alt : ''} loading={i === 0 ? 'eager' : 'lazy'} />
    </figure>
  ))}
  {images.length > 1 && (
    <div class="slideshow__dots">
      {images.map((_, i) => (
        <button type="button" class="slideshow__dot" data-i={i} aria-label={`Photo ${i + 1}`}></button>
      ))}
    </div>
  )}
</div>

<style>
  .slideshow {
    position: relative; aspect-ratio: 16 / 9; margin: 0;
    border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border-light);
    box-shadow: var(--shadow-md);
  }
  .slideshow__slide {
    position: absolute; inset: 0; margin: 0; opacity: 0;
    transition: opacity 1s ease;
  }
  .slideshow__slide[data-active='true'] { opacity: 1; }
  .slideshow__slide img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .slideshow__dots {
    position: absolute; bottom: 0.7rem; left: 0; right: 0;
    display: flex; gap: 0.45rem; justify-content: center; z-index: 1;
  }
  .slideshow__dot {
    width: 9px; height: 9px; border-radius: 50%; border: 0; padding: 0; cursor: pointer;
    background: rgba(255, 255, 255, 0.55);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.2);
  }
  .slideshow__dot[data-active='true'] { background: var(--gold); }
</style>

<script>
  for (const el of document.querySelectorAll<HTMLElement>('[data-slideshow]')) {
    const slides = Array.from(el.querySelectorAll<HTMLElement>('.slideshow__slide'));
    const dots = Array.from(el.querySelectorAll<HTMLElement>('.slideshow__dot'));
    let i = 0;
    const show = (n: number) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((s, k) => s.setAttribute('data-active', k === i ? 'true' : 'false'));
      dots.forEach((d, k) => d.setAttribute('data-active', k === i ? 'true' : 'false'));
    };
    dots.forEach((d, k) => d.addEventListener('click', () => show(k)));
    show(0);
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce && slides.length > 1) setInterval(() => show(i + 1), 4500);
  }
</script>
