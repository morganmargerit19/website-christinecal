---
/**
 * Champ d'étoiles dessiné sur un canvas plein écran :
 * scintillement doux + très légère dérive parallaxe au scroll.
 * Respecte prefers-reduced-motion (rendu statique dans ce cas).
 */
---
<canvas class="starfield" aria-hidden="true"></canvas>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('.starfield');

  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const DPR = Math.min(window.devicePixelRatio || 1, 2);

    interface Star {
      x: number; y: number; r: number;
      base: number; phase: number; speed: number; gold: boolean;
    }

    let stars: Star[] = [];
    let w = 0;
    let h = 0;

    // Parallaxe douce au mouvement de la souris (souris fine uniquement).
    const finePointer = window.matchMedia('(pointer: fine)').matches;
    const parallax = !reduceMotion && finePointer;
    let px = 0, py = 0, tpx = 0, tpy = 0; // position lissée / cible (-1..1)
    if (parallax) {
      window.addEventListener('pointermove', (e) => {
        tpx = (e.clientX / w - 0.5) * 2;
        tpy = (e.clientY / h - 0.5) * 2;
      }, { passive: true });
    }

    function seed() {
      w = window.innerWidth;
      h = window.innerHeight;
      canvas.width = w * DPR;
      canvas.height = h * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
      const count = Math.min(220, Math.floor((w * h) / 9000));
      stars = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: Math.random() * 1.2 + 0.3,
        base: Math.random() * 0.5 + 0.35,
        phase: Math.random() * Math.PI * 2,
        speed: Math.random() * 0.8 + 0.4,
        gold: Math.random() < 0.12,
      }));
    }

    function draw(t: number) {
      ctx.clearRect(0, 0, w, h);
      // Lissage du décalage souris (les grosses étoiles, plus « proches », bougent plus).
      px += (tpx - px) * 0.05;
      py += (tpy - py) * 0.05;
      const drift = (window.scrollY || 0) * 0.04;
      for (const s of stars) {
        const tw = reduceMotion ? 1 : 0.6 + 0.4 * Math.sin(t / 1000 * s.speed + s.phase);
        const depth = 3 + s.r * 6;
        const x = s.x + px * depth;
        const y = (s.y - drift + py * depth + h) % h;
        ctx.globalAlpha = s.base * tw;
        ctx.fillStyle = s.gold ? '#e6d49a' : '#ffffff';
        ctx.beginPath();
        ctx.arc(x, y, s.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }

    seed();
    if (reduceMotion) {
      draw(0);
      window.addEventListener('resize', () => { seed(); draw(0); }, { passive: true });
    } else {
      const loop = (t: number) => { draw(t); requestAnimationFrame(loop); };
      requestAnimationFrame(loop);
      window.addEventListener('resize', seed, { passive: true });
    }
  }
</script>
