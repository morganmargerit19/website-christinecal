---
/**
 * Vidéo YouTube en « façade » : on n'affiche d'abord qu'une vignette + bouton ▸.
 * L'iframe (youtube-nocookie) n'est injectée qu'au clic.
 *  - Respecte la vie privée (aucun cookie YouTube avant action de l'internaute).
 *  - Plus rapide (pas de player chargé tant qu'on ne lance pas).
 *  - Répond au souhait de Christine : « déclencher la vidéo via le site ».
 *
 * Si `cover` est fourni (jaquette du DVD), elle s'affiche À CÔTÉ de la vidéo,
 * avec la mention de droits posée SOUS la jaquette (souhait de Christine).
 */
import { base } from '../i18n/utils';

interface Props {
  id: string;
  title?: string;
  meta?: string;
  /** Mention de droits (ex. `debowska`). */
  credit?: 'debowska';
  /** Jaquette du DVD (chemin sous /images/…), affichée à côté de la vidéo. */
  cover?: string;
  coverAlt?: string;
  /** Libellé d'action traduit (aria-label + titre de l'iframe). */
  playLabel?: string;
}
const { id, title, meta, credit, cover, coverAlt, playLabel = 'Lancer la vidéo' } = Astro.props;
const thumb = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---
<figure class:list={["video-card", cover && "video-card--with-cover"]}>
  <div class:list={[cover && "video-card__row"]}>
    <div class="frame">
      <button
        class="video-facade"
        data-video-id={id}
        type="button"
        aria-label={`${playLabel}${title ? ' : ' + title : ''}`}
      >
        <img src={thumb} alt="" loading="lazy" width="480" height="360" />
        <span class="video-facade__play" aria-hidden="true">▸</span>
      </button>
    </div>

    {cover && (
      <figure class="video-cover">
        <img src={base + cover} alt={coverAlt ?? (title ? `Jaquette — ${title}` : '')} loading="lazy" />
        {credit === 'debowska' && (
          <figcaption class="video-credit">
            DVD DEBOWSKA avec Autorisation exceptionnelle de diffusion de Konstanty
            UDALA DEBOWSKA en hommage pour son épouse Malgorzata Debowska —{' '}
            <a href="https://www.debowska.fr/" target="_blank" rel="noopener">Visiter son site</a>
          </figcaption>
        )}
      </figure>
    )}
  </div>

  {(title || meta || (credit === 'debowska' && !cover)) && (
    <figcaption>
      {title && <strong>{title}</strong>}
      {meta && <span>{meta}</span>}
      {credit === 'debowska' && !cover && (
        <span class="video-credit">
          DVD DEBOWSKA avec Autorisation exceptionnelle de diffusion de Konstanty
          UDALA DEBOWSKA en hommage pour son épouse Malgorzata Debowska —{' '}
          <a href="https://www.debowska.fr/" target="_blank" rel="noopener">Visiter son site</a>
        </span>
      )}
    </figcaption>
  )}
</figure>

<style>
  .video-facade {
    position: absolute; inset: 0; width: 100%; height: 100%;
    padding: 0; border: 0; cursor: pointer; background: var(--indigo-900);
    display: grid; place-items: center;
  }
  .video-facade img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; opacity: 0.7; transition: opacity var(--transition), transform var(--transition);
  }
  .video-facade:hover img { opacity: 0.95; transform: scale(1.03); }
  .video-facade__play {
    position: relative; z-index: 1;
    width: 4.2rem; height: 4.2rem; border-radius: 50%;
    display: grid; place-items: center;
    background: linear-gradient(120deg, var(--gold), var(--gold-soft));
    color: var(--indigo-950); font-size: 1.8rem; padding-left: 0.2em;
    box-shadow: 0 8px 30px rgba(7, 6, 26, 0.5);
    transition: transform var(--transition);
  }
  .video-facade:hover .video-facade__play { transform: scale(1.08); }

  /* Vidéo + jaquette côte à côte */
  .video-card--with-cover { max-width: 760px; flex-basis: 480px; }
  .video-card__row { display: flex; gap: var(--space-3); align-items: flex-start; }
  .video-card__row .frame { flex: 1 1 auto; min-width: 0; }
  .video-cover { flex: 0 0 clamp(118px, 26%, 168px); margin: 0; }
  .video-cover img {
    width: 100%; height: auto; display: block;
    border-radius: var(--radius); box-shadow: var(--shadow-md);
    border: 1px solid var(--border-light);
  }
  .video-cover .video-credit {
    display: block; margin-top: 0.55em; font-size: 0.74em;
    font-style: italic; line-height: 1.4; opacity: 0.9;
  }
  .video-cover .video-credit a { color: var(--gold); text-decoration: underline; }
  @media (max-width: 540px) {
    .video-card__row { flex-direction: column; align-items: center; }
    .video-cover { flex-basis: auto; max-width: 200px; }
  }
</style>

<script>
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.video-facade')) {
    btn.addEventListener('click', () => {
      const id = btn.dataset.videoId;
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = btn.getAttribute('aria-label') ?? 'Vidéo';
      iframe.allow = 'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture';
      iframe.allowFullscreen = true;
      btn.replaceWith(iframe);
    });
  }
</script>
