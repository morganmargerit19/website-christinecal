# christinecal.com — hébergement mutualisé OVH (Apache)
# Ce fichier n'a d'effet que sur OVH ; il est ignoré par Vercel (preview /v3/).

# --- 1) HTTPS + domaine canonique (www) ---------------------------------
# OVH termine le TLS en amont : on teste X-Forwarded-Proto et NON %{HTTPS}
# (qui vaut « off » côté Apache même en HTTPS → boucle de redirection infinie).
RewriteEngine On
RewriteCond %{HTTP:X-Forwarded-Proto} !https [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.christinecal.com%{REQUEST_URI} [L,R=301]

# Redirections SEO « ancien WordPress → V3 » : à compléter avant la bascule.
# Les slugs V3 diffèrent de l'ancien WordPress : mapper chaque URL indexée
# (Search Console) vers la page V3 la plus proche, sinon laisser répondre 404.
# Ex. : RewriteRule ^le-mont-shasta/?$ /eveil-au-soi/les-intra-telos-mont-shasta/ [L,R=301]

# --- 2) Page 404 personnalisée ------------------------------------------
ErrorDocument 404 /404.html

# --- 3) Compression -----------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# --- 4) Cache navigateur ------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
  # Assets fingerprintés par Astro (/_astro/...) : immuables, cache long
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML : toujours revalider pour servir la dernière version publiée
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
